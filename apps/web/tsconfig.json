{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@droploop/media": ["../../packages/media/src/index.ts"],
      "@droploop/pipeline": ["../../packages/pipeline/src/index.ts"],
      "@droploop/schemas": ["../../packages/schemas/src/index.ts"],
      "@droploop/ui": ["../../packages/ui/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
